<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="A growing collection of focused tools for tabletop role-playing games."
    />
    <title>Zippin's Tookit</title>
    <link
      href="https://fonts.googleapis.com/icon?family=Material+Icons"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=MedievalSharp&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Almendra:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="toolkit">
      <h1>Zippin's Tookit</h1>
      <p>A growing collection of focused tools for tabletop role-playing games.</p>

      <section aria-labelledby="tools-title">
        <h2 id="tools-title">Available tools</h2>
        <a class="toolkit__tool" href="fantasy-calendar/">
          <span class="material-icons" aria-hidden="true">calendar_month</span>
          <div>
            <h3>Fantasy Calendar</h3>
            <p>
              Explore the Calendar of Harptos, festivals, leap days, and moon phases.
            </p>
          </div>
        </a>
      </section>
    </main>
  </body>
</html>
