{
  "name": "zippin-toolkit",
  "version": "1.0.1",
  "description": "A collection of focused tools for tabletop role-playing games.",
  "scripts": {
    "build": "webpack --config webpack.prod.js",
    "start": "webpack serve --open --config webpack.dev.js",
    "lint": "eslint app/src fantasy-calendar/src fantasy-calendar/tests",
    "lint:styles": "stylelint \"app/src/**/*.scss\" \"fantasy-calendar/src/**/*.scss\"",
    "test": "npm run test:unit",
    "test:unit": "node -e \"require('fs').rmSync('.tmp-tests', { recursive: true, force: true })\" && npx tsc -p tsconfig.test.json && node --test .tmp-tests/fantasy-calendar/tests/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruslan-sh/zippin-toolkit.git"
  },
  "keywords": [
    "html",
    "js",
    "typescript",
    "ttrpg",
    "toolkit",
    "fantasy-calendar"
  ],
  "author": "Ruslan Shokhirev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ruslan-sh/zippin-toolkit/issues"
  },
  "homepage": "https://ruslan-sh.github.io/zippin-toolkit/",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "css-loader": "^7",
    "css-minimizer-webpack-plugin": "^7",
    "eslint": "^9.39.2",
    "html-webpack-plugin": "^5",
    "mini-css-extract-plugin": "^2",
    "postcss-scss": "^4.0.9",
    "sass": "^1.93.3",
    "sass-loader": "^16.0.6",
    "source-map-loader": "^5",
    "style-loader": "^4",
    "stylelint": "^17.1.1",
    "stylelint-config-standard": "^40.0.0",
    "ts-loader": "^9",
    "typescript": "^5",
    "webpack": "^5",
    "webpack-cli": "^6",
    "webpack-dev-server": "^5"
  }
}
